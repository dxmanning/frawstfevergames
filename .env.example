# Use the non-SRV (multi-host) form — works behind VPNs that block SRV DNS.
# Get this from Atlas → Connect → Drivers → toggle "I am using driver 2.2.11 or earlier".
MONGODB_URI="mongodb://USER:PASS@ac-xxxxx-shard-00-00.xxxxx.mongodb.net:27017,ac-xxxxx-shard-00-01.xxxxx.mongodb.net:27017,ac-xxxxx-shard-00-02.xxxxx.mongodb.net:27017/DBNAME?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&appName=APPNAME"
MONGODB_DB="DBNAME"
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="choose-a-strong-password"
AUTH_SECRET="run: openssl rand -base64 32"
STORE_NAME="Retro Rack"
STORE_CURRENCY="USD"
STORE_LOCAL_PICKUP_CITY="Your City, ST"
NEXT_PUBLIC_STORE_NAME="Retro Rack"
NEXT_PUBLIC_STORE_CURRENCY="USD"
PRICE_SHEET_CSV_URL=""

# PriceCharting API token — paste the "t=…" value from your price-guide links
PRICECHARTING_TOKEN=""
PRICECHARTING_CUSTOM_CSV_URL=""
